#!/usr/bin/env bash

set -euo pipefail

if [[ "$#" -ne 2 ]]; then
  printf '%s\n' "usage: $0 IMAGE_DIR PHARO_VERSION" >&2
  exit 64
fi

IMAGE_DIR=$1
PHARO_VERSION=$2

if command -v curl >/dev/null 2>&1; then
  download_to() {
    curl -fsSL "$1" -o "$2"
  }
elif command -v wget >/dev/null 2>&1; then
  download_to() {
    wget -q -O "$2" "$1"
  }
else
  printf '%s\n' "curl or wget is required to bootstrap Pharo" >&2
  exit 1
fi

if ! command -v unzip >/dev/null 2>&1; then
  printf '%s\n' "unzip is required to bootstrap Pharo" >&2
  exit 1
fi

UNAME_S=${POSTERN_BOOTSTRAP_OS:-$(uname -s)}
UNAME_M=${POSTERN_BOOTSTRAP_ARCH:-$(uname -m)}
WINDOWS_UNDER_ARM64=0
WINDOWS_STACK_VM=0

case "$UNAME_S" in
  Darwin)
    OS_NAME=Darwin
    ;;
  Linux)
    OS_NAME=Linux
    ;;
  MSYS*|CYGWIN*|MINGW*)
    OS_NAME=Windows
    ;;
  *)
    printf '%s\n' "unsupported OS: $UNAME_S" >&2
    exit 1
    ;;
esac

case "$UNAME_M" in
  x86_64|amd64|x86*)
    IMAGE_ARCH=x86_64
    VM_ARCH=x86_64
    ;;
  arm64)
    IMAGE_ARCH=arm64
    if [ "$OS_NAME" = "Linux" ]; then
      VM_ARCH=aarch64
    else
      VM_ARCH=arm64
    fi
    ;;
  aarch64)
    IMAGE_ARCH=aarch64
    VM_ARCH=aarch64
    ;;
  *)
    printf '%s\n' "unsupported architecture: $UNAME_M" >&2
    exit 1
    ;;
esac

if [[ "$OS_NAME" == "Windows" ]]; then
  case "$UNAME_S/$UNAME_M" in
    *ARM64*/x86_64|*ARM64*/amd64|*ARM64*/x86*|*ARM64*/arm64|*ARM64*/aarch64|*/arm64|*/aarch64)
      WINDOWS_UNDER_ARM64=1
      ;;
  esac
fi

if [[ "$OS_NAME" == "Windows" && "$WINDOWS_UNDER_ARM64" -eq 1 ]]; then
  # Git Bash on Windows ARM commonly reports uname -m as x86_64 under the x64
  # emulation layer. Pharo's Windows x86_64 Stack VM runs reliably there,
  # while the default JIT VM does not.
  IMAGE_ARCH=x86_64
  VM_ARCH=x86_64
  WINDOWS_STACK_VM=1
  printf '%s\n' "Detected Windows ARM64 host; bootstrapping the Windows x86_64 Stack VM under emulation."
fi

VM_CHANNEL=stable
if [[ "$OS_NAME" == "Linux" && "$VM_ARCH" == "aarch64" ]]; then
  # Pharo currently publishes Linux ARM64 VMs only as "latest", not "stable".
  VM_CHANNEL=latest
fi

FILES_URL=https://files.pharo.org/get-files/${PHARO_VERSION}
IMAGE_URL=${FILES_URL}/pharoImage-${IMAGE_ARCH}.zip
VM_URL=${FILES_URL}/pharo-vm-${OS_NAME}-${VM_ARCH}-${VM_CHANNEL}.zip
if [[ "$WINDOWS_STACK_VM" -eq 1 ]]; then
  STACK_VM_SERIES=$((10#$PHARO_VERSION / 10))
  VM_URL=https://files.pharo.org/vm/pharo-spur64-headless/Windows-x86_64/stableStackVM${STACK_VM_SERIES}.zip
fi
mkdir -p "$IMAGE_DIR"
TMP_DIR=$(mktemp -d "${IMAGE_DIR}/bootstrap.XXXXXX")

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT HUP INT TERM

IMAGE_ZIP=$TMP_DIR/image.zip
VM_ZIP=$TMP_DIR/vm.zip
IMAGE_UNZIP_DIR=$TMP_DIR/image

mkdir -p "$IMAGE_DIR" "$IMAGE_UNZIP_DIR"

printf '%s\n' "Downloading the latest ${PHARO_VERSION} Image:"
printf '%s\n' "    ${IMAGE_URL}"
download_to "$IMAGE_URL" "$IMAGE_ZIP"
unzip -q "$IMAGE_ZIP" -d "$IMAGE_UNZIP_DIR"

PHARO_IMAGE=$(find "$IMAGE_UNZIP_DIR" -name '*.image' | head -n 1)
PHARO_CHANGES=$(find "$IMAGE_UNZIP_DIR" -name '*.changes' | head -n 1)
PHARO_SOURCES=$(find "$IMAGE_UNZIP_DIR" -name '*.sources' | head -n 1)

if [[ -z "$PHARO_IMAGE" || -z "$PHARO_CHANGES" || -z "$PHARO_SOURCES" ]]; then
  printf '%s\n' "downloaded image archive did not contain the expected Pharo files" >&2
  exit 1
fi

mv -f "$PHARO_IMAGE" "$IMAGE_DIR/Pharo.image"
mv -f "$PHARO_CHANGES" "$IMAGE_DIR/Pharo.changes"
mv -f "$PHARO_SOURCES" "$IMAGE_DIR/$(basename "$PHARO_SOURCES")"

printf '%s\n' "Downloading the pharoVM:"
printf '%s\n' "    ${VM_URL}"
download_to "$VM_URL" "$VM_ZIP"
rm -rf "$IMAGE_DIR/pharo-vm"
mkdir -p "$IMAGE_DIR/pharo-vm"
unzip -oq "$VM_ZIP" -d "$IMAGE_DIR/pharo-vm"

case "$OS_NAME" in
  Darwin)
    VM_UI_REL=$(find "$IMAGE_DIR/pharo-vm" -name Pharo.app -type d | head -n 1)
    if [[ -z "$VM_UI_REL" ]]; then
      printf '%s\n' "downloaded VM archive did not contain Pharo.app" >&2
      exit 1
    fi
    VM_UI_REL=${VM_UI_REL#"$IMAGE_DIR"/}
    VM_UI_REL=${VM_UI_REL}/Contents/MacOS/Pharo
    HEADLESS_FLAGS="--headless"
    ;;
  Linux)
    VM_UI_REL=pharo-vm/pharo
    if [[ ! -x "$IMAGE_DIR/$VM_UI_REL" ]]; then
      printf '%s\n' "downloaded VM archive did not contain a runnable pharo binary" >&2
      exit 1
    fi
    # Force truly headless startup on Linux regardless of whether the downloaded
    # VM build defaults to headless or interactive mode.
    HEADLESS_FLAGS="--headless --vm-display-null"
    ;;
  Windows)
    VM_HEADLESS_REL=$(find "$IMAGE_DIR/pharo-vm" -name PharoConsole.exe -type f | head -n 1)
    VM_UI_REL=$(find "$IMAGE_DIR/pharo-vm" -name Pharo.exe -type f | head -n 1)
    if [[ -z "$VM_HEADLESS_REL" && -z "$VM_UI_REL" ]]; then
      printf '%s\n' "downloaded VM archive did not contain a runnable Pharo executable" >&2
      exit 1
    fi
    if [[ -z "$VM_HEADLESS_REL" ]]; then
      VM_HEADLESS_REL=$VM_UI_REL
    fi
    if [[ -z "$VM_UI_REL" ]]; then
      VM_UI_REL=$VM_HEADLESS_REL
    fi
    VM_HEADLESS_REL=${VM_HEADLESS_REL#"$IMAGE_DIR"/}
    VM_UI_REL=${VM_UI_REL#"$IMAGE_DIR"/}
    HEADLESS_FLAGS="--headless"
    ;;
esac

cat >"$IMAGE_DIR/pharo" <<EOF
#!/usr/bin/env bash
set -euo pipefail
DIR=\$(CDPATH= cd -- "\$(dirname -- "\$0")" && pwd)
set -f
exec "\$DIR/${VM_HEADLESS_REL:-$VM_UI_REL}" $HEADLESS_FLAGS "\$@"
EOF
chmod +x "$IMAGE_DIR/pharo"

cat >"$IMAGE_DIR/pharo-ui" <<EOF
#!/usr/bin/env bash
set -euo pipefail
DIR=\$(CDPATH= cd -- "\$(dirname -- "\$0")" && pwd)
set -f
exec "\$DIR/$VM_UI_REL" "\$@"
EOF
chmod +x "$IMAGE_DIR/pharo-ui"

printf '%s\n' "$IMAGE_DIR/pharo"
