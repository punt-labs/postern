#!/usr/bin/env sh

set -eu

if [ "$#" -ne 2 ]; then
  echo "usage: $0 IMAGE_DIR PHARO_VERSION" >&2
  exit 64
fi

IMAGE_DIR=$1
PHARO_VERSION=$2

if command -v curl >/dev/null 2>&1; then
  download_to() {
    curl -fsSL "$1" -o "$2"
  }
elif command -v wget >/dev/null 2>&1; then
  download_to() {
    wget -q -O "$2" "$1"
  }
else
  echo "curl or wget is required to bootstrap Pharo" >&2
  exit 1
fi

if ! command -v unzip >/dev/null 2>&1; then
  echo "unzip is required to bootstrap Pharo" >&2
  exit 1
fi

UNAME_S=${POSTERN_BOOTSTRAP_OS:-$(uname -s)}
UNAME_M=${POSTERN_BOOTSTRAP_ARCH:-$(uname -m)}

case "$UNAME_S" in
  Darwin)
    OS_NAME=Darwin
    ;;
  Linux)
    OS_NAME=Linux
    ;;
  MSYS*|CYGWIN*|MINGW*)
    OS_NAME=Windows
    ;;
  *)
    echo "unsupported OS: $UNAME_S" >&2
    exit 1
    ;;
esac

case "$UNAME_M" in
  x86_64|amd64|x86*)
    IMAGE_ARCH=x86_64
    VM_ARCH=x86_64
    ;;
  arm64)
    IMAGE_ARCH=arm64
    if [ "$OS_NAME" = "Linux" ]; then
      VM_ARCH=aarch64
    else
      VM_ARCH=arm64
    fi
    ;;
  aarch64)
    IMAGE_ARCH=aarch64
    VM_ARCH=aarch64
    ;;
  *)
    echo "unsupported architecture: $UNAME_M" >&2
    exit 1
    ;;
esac

VM_CHANNEL=stable
if [ "$OS_NAME" = "Linux" ] && [ "$VM_ARCH" = "aarch64" ]; then
  # Pharo currently publishes Linux ARM64 VMs only as "latest", not "stable".
  VM_CHANNEL=latest
fi

FILES_URL=https://files.pharo.org/get-files/$PHARO_VERSION
IMAGE_URL=$FILES_URL/pharoImage-$IMAGE_ARCH.zip
VM_URL=$FILES_URL/pharo-vm-$OS_NAME-$VM_ARCH-$VM_CHANNEL.zip
mkdir -p "$IMAGE_DIR"
TMP_DIR=$(mktemp -d "$IMAGE_DIR/bootstrap.XXXXXX")

cleanup() {
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT HUP INT TERM

IMAGE_ZIP=$TMP_DIR/image.zip
VM_ZIP=$TMP_DIR/vm.zip
IMAGE_UNZIP_DIR=$TMP_DIR/image

mkdir -p "$IMAGE_DIR" "$IMAGE_UNZIP_DIR"

echo "Downloading the latest $PHARO_VERSION Image:"
echo "    $IMAGE_URL"
download_to "$IMAGE_URL" "$IMAGE_ZIP"
unzip -q "$IMAGE_ZIP" -d "$IMAGE_UNZIP_DIR"

PHARO_IMAGE=$(find "$IMAGE_UNZIP_DIR" -name '*.image' | head -n 1)
PHARO_CHANGES=$(find "$IMAGE_UNZIP_DIR" -name '*.changes' | head -n 1)
PHARO_SOURCES=$(find "$IMAGE_UNZIP_DIR" -name '*.sources' | head -n 1)

if [ -z "$PHARO_IMAGE" ] || [ -z "$PHARO_CHANGES" ] || [ -z "$PHARO_SOURCES" ]; then
  echo "downloaded image archive did not contain the expected Pharo files" >&2
  exit 1
fi

mv -f "$PHARO_IMAGE" "$IMAGE_DIR/Pharo.image"
mv -f "$PHARO_CHANGES" "$IMAGE_DIR/Pharo.changes"
mv -f "$PHARO_SOURCES" "$IMAGE_DIR/$(basename "$PHARO_SOURCES")"

echo "Downloading the latest pharoVM:"
echo "    $VM_URL"
download_to "$VM_URL" "$VM_ZIP"
rm -rf "$IMAGE_DIR/pharo-vm"
mkdir -p "$IMAGE_DIR/pharo-vm"
unzip -oq "$VM_ZIP" -d "$IMAGE_DIR/pharo-vm"

case "$OS_NAME" in
  Darwin)
    VM_UI_REL=$(find "$IMAGE_DIR/pharo-vm" -name Pharo.app -type d | head -n 1)
    if [ -z "$VM_UI_REL" ]; then
      echo "downloaded VM archive did not contain Pharo.app" >&2
      exit 1
    fi
    VM_UI_REL=${VM_UI_REL#"$IMAGE_DIR"/}
    VM_UI_REL=$VM_UI_REL/Contents/MacOS/Pharo
    HEADLESS_FLAG=--headless
    ;;
  Linux)
    VM_UI_REL=pharo-vm/pharo
    if [ ! -x "$IMAGE_DIR/$VM_UI_REL" ]; then
      echo "downloaded VM archive did not contain a runnable pharo binary" >&2
      exit 1
    fi
    HEADLESS_FLAG=--nodisplay
    ;;
  Windows)
    VM_UI_REL=$(find "$IMAGE_DIR/pharo-vm" -name Pharo.exe -o -name PharoConsole.exe | head -n 1)
    if [ -z "$VM_UI_REL" ]; then
      echo "downloaded VM archive did not contain a runnable Pharo executable" >&2
      exit 1
    fi
    VM_UI_REL=${VM_UI_REL#"$IMAGE_DIR"/}
    HEADLESS_FLAG=--headless
    ;;
esac

cat >"$IMAGE_DIR/pharo" <<EOF
#!/usr/bin/env sh
set -eu
DIR=\$(CDPATH= cd -- "\$(dirname -- "\$0")" && pwd)
set -f
exec "\$DIR/$VM_UI_REL" $HEADLESS_FLAG "\$@"
EOF
chmod +x "$IMAGE_DIR/pharo"

cat >"$IMAGE_DIR/pharo-ui" <<EOF
#!/usr/bin/env sh
set -eu
DIR=\$(CDPATH= cd -- "\$(dirname -- "\$0")" && pwd)
set -f
exec "\$DIR/$VM_UI_REL" "\$@"
EOF
chmod +x "$IMAGE_DIR/pharo-ui"

echo "$IMAGE_DIR/pharo"
